TRELLO_API_KEY=deine_api_key_hier
TRELLO_API_TOKEN=dein_api_token_hier

# Optional: restrict Cloud Run to your team (set when deploying)
# MCP_ACCESS_TOKEN=your-secret-token-here

# OAuth for Claude.ai Settings > Connectors
BASE_URL=

# Redis (Upstash) for OAuth token storage - required for multi-instance Cloud Run
REDIS_HOST=your-redis-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password